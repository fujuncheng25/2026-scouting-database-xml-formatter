# Remote formal DB (read-only source)
REMOTE_POSTGRES_HOST=localhost
REMOTE_POSTGRES_PORT=5432
REMOTE_POSTGRES_USER=postgres
REMOTE_POSTGRES_PASSWORD=postgres
REMOTE_POSTGRES_DB=scouting

# Local editable DB (owned by this project)
LOCAL_POSTGRES_HOST=localhost
LOCAL_POSTGRES_PORT=5432
LOCAL_POSTGRES_USER=postgres
LOCAL_POSTGRES_PASSWORD=postgres
LOCAL_POSTGRES_DB=scouting_local

# Optional fallback keys for backwards compatibility
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scouting

# Runtime
PORT=5000
REQUIRE_AUTH=false
